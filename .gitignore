# =================================================================
# MIR Consulting — repo .gitignore
# Anything that is environment-specific, generated, or contains
# secrets/credentials goes here.
# =================================================================

# ----- Secrets / env -----
.env
.env.*
*.env
!*.env.example
*.pem
*.key
credentials.json
*credentials.json*
*token.json*
.credentials

# ----- Dependencies -----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ----- Build output -----
/build
build/
dist/
.next/
out/

# ----- Caches -----
.cache/
.parcel-cache/
.eslintcache
.npm
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/

# ----- IDE / OS -----
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# ----- Logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Coverage -----
/coverage
htmlcov/
.coverage
.coverage.*

# ----- Agent / preview-only artifacts (safe to ignore on fresh repo) -----
.emergent/
test_reports/
test_result.md
design_guidelines.json
memory/test_credentials.md
dump.rdb

# ----- Misc archives -----
*.zip
*.tar
*.tar.gz
*.tgz
frontend/node_modules/.cache/default-development/0.pack
